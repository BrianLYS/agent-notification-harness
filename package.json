{
  "name": "agent-notification-harness",
  "version": "0.2.0",
  "description": "Tiny notification harness for agent runs, media artifacts, and Codex stop hooks.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-notification-harness-init": "./scripts/agent-notification-init.mjs",
    "agent-notify-init": "./scripts/agent-notification-init.mjs",
    "agent-notify": "./scripts/agent-notify.mjs",
    "agent-notify-image": "./scripts/agent-notify-image.mjs",
    "agent-notify-media": "./scripts/agent-notify-media.mjs",
    "codex-stop-notify": "./scripts/codex-stop-notify.mjs"
  },
  "exports": {
    "./queue": "./scripts/agent-notify-queue.mjs"
  },
  "files": [
    "scripts/*.mjs",
    "docs/*.md",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run test:notify && npm run test:image && npm run test:media && npm run test:codex-stop && npm run test:init && npm run test:installed",
    "test:notify": "node scripts/agent-notify.test.mjs",
    "test:image": "node scripts/agent-notify-image.test.mjs",
    "test:media": "node scripts/agent-notify-media.test.mjs",
    "test:codex-stop": "node scripts/codex-stop-notify.test.mjs",
    "test:init": "node scripts/agent-notification-init.test.mjs",
    "test:installed": "node scripts/installed-package.test.mjs",
    "release:check": "npm test && npm pack --dry-run",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "engines": {
    "node": ">=20"
  }
}
